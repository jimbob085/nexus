{
  "name": "nexus-command",
  "version": "0.1.0",
  "type": "module",
  "license": "MIT",
  "private": true,
  "engines": {
    "node": ">=20.0.0"
  },
  "bin": {
    "nexus-command": "./bin/cli.ts"
  },
  "exports": {
    ".": {
      "types": "./dist/src/index.d.ts",
      "import": "./dist/src/index.js"
    },
    "./db": {
      "types": "./dist/src/db/index.d.ts",
      "import": "./dist/src/db/index.js"
    },
    "./db/schema": {
      "types": "./dist/src/db/schema.d.ts",
      "import": "./dist/src/db/schema.js"
    },
    "./logger": {
      "types": "./dist/src/logger.d.ts",
      "import": "./dist/src/logger.js"
    },
    "./config": {
      "types": "./dist/src/config.d.ts",
      "import": "./dist/src/config.js"
    },
    "./settings/service": {
      "types": "./dist/src/settings/service.d.ts",
      "import": "./dist/src/settings/service.js"
    },
    "./telemetry/usage-reporter": {
      "types": "./dist/src/telemetry/usage-reporter.d.ts",
      "import": "./dist/src/telemetry/usage-reporter.js"
    },
    "./adapters": {
      "types": "./dist/src/adapters/index.d.ts",
      "import": "./dist/src/adapters/index.js"
    },
    "./adapters/interfaces/commit-provider": {
      "types": "./dist/src/adapters/interfaces/commit-provider.d.ts",
      "import": "./dist/src/adapters/interfaces/commit-provider.js"
    },
    "./adapters/interfaces/communication-adapter": {
      "types": "./dist/src/adapters/interfaces/communication-adapter.d.ts",
      "import": "./dist/src/adapters/interfaces/communication-adapter.js"
    },
    "./adapters/interfaces/knowledge-source": {
      "types": "./dist/src/adapters/interfaces/knowledge-source.d.ts",
      "import": "./dist/src/adapters/interfaces/knowledge-source.js"
    },
    "./adapters/interfaces/llm-provider": {
      "types": "./dist/src/adapters/interfaces/llm-provider.d.ts",
      "import": "./dist/src/adapters/interfaces/llm-provider.js"
    },
    "./adapters/interfaces/project-registry": {
      "types": "./dist/src/adapters/interfaces/project-registry.d.ts",
      "import": "./dist/src/adapters/interfaces/project-registry.js"
    },
    "./adapters/interfaces/tenant-resolver": {
      "types": "./dist/src/adapters/interfaces/tenant-resolver.d.ts",
      "import": "./dist/src/adapters/interfaces/tenant-resolver.js"
    },
    "./adapters/interfaces/ticket-tracker": {
      "types": "./dist/src/adapters/interfaces/ticket-tracker.d.ts",
      "import": "./dist/src/adapters/interfaces/ticket-tracker.js"
    },
    "./adapters/interfaces/usage-sink": {
      "types": "./dist/src/adapters/interfaces/usage-sink.d.ts",
      "import": "./dist/src/adapters/interfaces/usage-sink.js"
    },
    "./adapters/registry": {
      "types": "./dist/src/adapters/registry.d.ts",
      "import": "./dist/src/adapters/registry.js"
    }
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsx bin/cli.ts",
    "dev:server": "tsx --watch src/index.ts",
    "start": "tsx bin/cli.ts",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:studio": "drizzle-kit studio",
    "typecheck": "tsc --noEmit",
    "lint": "eslint \"src/**/*.ts\"",
    "lint:fix": "eslint \"src/**/*.ts\" --fix",
    "format:check": "prettier --check \"src/**/*.ts\"",
    "format:write": "prettier --write \"src/**/*.ts\"",
    "test": "vitest",
    "test:run": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:eval:intent": "tsx scripts/eval_intent.ts"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.78.0",
    "@electric-sql/pglite": "^0.3.16",
    "@fastify/helmet": "^13.0.2",
    "@fastify/static": "^9.0.0",
    "@fastify/websocket": "^11.2.0",
    "@google/genai": "^1.45.0",
    "@google/generative-ai": "^0.24.1",
    "discord.js": "^14.16.0",
    "dotenv": "^16.4.7",
    "drizzle-orm": "^0.30.10",
    "fastify": "^5.7.4",
    "gray-matter": "^4.0.3",
    "openai": "^6.29.0",
    "pino": "^9.6.0",
    "pino-pretty": "^13.0.0",
    "playwright": "^1.58.2",
    "postgres": "^3.4.4",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "@typescript-eslint/eslint-plugin": "^8.56.1",
    "@typescript-eslint/parser": "^8.56.1",
    "@vitest/coverage-v8": "^4.0.18",
    "drizzle-kit": "^0.21.4",
    "eslint": "^8.57.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "eslint-plugin-vitest": "^0.5.4",
    "prettier": "^3.8.1",
    "tsx": "^4.19.0",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  },
  "optionalDependencies": {
    "pgvector": "^0.2.1"
  }
}
